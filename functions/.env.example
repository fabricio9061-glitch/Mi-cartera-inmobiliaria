# ===== Credenciales de tu aplicación de Mercado Libre =====
# Copiá este archivo como  .env  (sin el .example) y completá los valores.

# App ID (Client ID) que te dio Mercado Libre al crear la aplicación
ML_CLIENT_ID=PONÉ_ACÁ_TU_APP_ID

# Clave secreta (Client Secret) de tu aplicación. Tratala como contraseña.
ML_CLIENT_SECRET=PONÉ_ACÁ_TU_CLIENT_SECRET

# URL de redirect. Debe ser EXACTAMENTE la misma que cargues en la app de ML.
# Es la dirección de la función callbackML (la sabrás tras el primer deploy).
# Tiene esta forma (reemplazá la región y el project id si difieren):
ML_REDIRECT_URI=https://us-central1-mi-cartera-inmobiliaria.cloudfunctions.net/callbackML

# País de Mercado Libre: Uruguay = MLU
ML_SITE=MLU

# Dominio de autorización del país (Uruguay)
ML_AUTH_DOMAIN=https://auth.mercadolibre.com.uy

# (Opcional) Categorías por defecto si la predicción automática falla.
# Las completaremos con los IDs reales de inmuebles de MLU si hace falta.
ML_CAT_SALE=
ML_CAT_RENT=
